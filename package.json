{
  "name": "@yume-dsl/token-walker",
  "version": "0.1.0",
  "description": "interpret / walk / execute token tree",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "tsup && node --import tsx tests/run-render-core-tests.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "yume-dsl",
    "dsl",
    "interpreter",
    "token",
    "ast",
    "visitor"
  ],
  "author": "Hoshino Yumeka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiba233/yume-dsl-token-walker.git"
  },
  "homepage": "https://github.com/chiba233/yume-dsl-token-walker#readme",
  "bugs": {
    "url": "https://github.com/chiba233/yume-dsl-token-walker/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yume-dsl-rich-text": "^0.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
