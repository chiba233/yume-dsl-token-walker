{
  "name": "yume-dsl-token-walker",
  "version": "1.2.0",
  "description": "Token walker core that interprets yume-dsl-rich-text token trees",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsup --target esnext",
    "test": "tsup --target esnext && node --import tsx tests/run-render-core-tests.ts",
    "test:coverage": "YUME_DSL_COVERAGE_SOURCEMAP=1 tsup --target esnext && c8 node --enable-source-maps --import tsx tests/run-render-core-tests.ts",
    "test:coverage:win": "set YUME_DSL_COVERAGE_SOURCEMAP=1&& tsup --target esnext && c8 node --enable-source-maps --import tsx tests/run-render-core-tests.ts",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "yume-dsl",
    "yume-dsl-rich-text",
    "dsl",
    "rich-text",
    "token-walker",
    "token-tree",
    "interpreter",
    "visitor",
    "renderer-core",
    "custom-markup"
  ],
  "author": "Hoshino Yumeka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiba233/yume-dsl-token-walker.git"
  },
  "homepage": "https://github.com/chiba233/yume-dsl-token-walker#readme",
  "bugs": {
    "url": "https://github.com/chiba233/yume-dsl-token-walker/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yume-dsl-rich-text": "^1.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "c8": "^11.0.0"
  }
}
